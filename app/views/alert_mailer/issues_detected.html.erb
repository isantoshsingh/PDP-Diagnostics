<h1 style="font-size: 24px; color: #202223; margin-bottom: 16px;">
  We noticed something on your product page
</h1>

<p style="margin-bottom: 16px;">
  Hi there,
</p>

<p style="margin-bottom: 16px;">
  Prowl detected <%= @issues.length == 1 ? "a potential issue" : "#{@issues.length} potential issues" %> on <strong><%= @product_page.title %></strong> that may affect your customers' ability to purchase.
</p>

<% @issues.each do |issue| %>
<div style="background-color: #fef3cd; border-left: 4px solid #f0b429; padding: 16px; margin-bottom: 16px; border-radius: 4px;">
  <strong style="color: #856404;"><%= issue.title %></strong>
  <p style="margin: 8px 0 0 0; color: #856404;"><%= issue.merchant_explanation %></p>

  <% if issue.merchant_suggested_fix.present? %>
  <div style="background-color: #f0faf5; border-left: 3px solid #008060; padding: 12px; margin-top: 12px; border-radius: 4px;">
    <strong style="color: #004c3f; font-size: 13px;">💡 Suggested fix:</strong>
    <p style="margin: 6px 0 0 0; color: #004c3f; font-size: 13px; white-space: pre-line;"><%= issue.merchant_suggested_fix %></p>
  </div>
  <% end %>

  <% if issue.ai_confirmed == true && issue.ai_confidence.present? %>
  <p style="margin: 10px 0 0 0; color: #2c6ecb; font-size: 13px;">
    🤖 AI confirmed this issue with <%= (issue.ai_confidence * 100).round %>% confidence.
  </p>
  <% end %>
</div>
<% end %>

<% if @has_screenshot %>
<div style="margin-bottom: 24px;">
  <p style="font-weight: 600; margin-bottom: 8px; color: #202223;">Here's what we saw:</p>
  <img src="<%= attachments['screenshot.png'].url %>"
       alt="Screenshot of <%= @product_page.title %>"
       style="max-width: 100%; border: 1px solid #e1e3e5; border-radius: 8px;" />
</div>
<% end %>

<p style="margin-bottom: 8px;">
  <strong>What this means:</strong>
</p>
<p style="margin-bottom: 16px;">
  <%= @issues.length == 1 ? "This issue has" : "These issues have" %> been detected and confirmed. We recommend reviewing the page to ensure customers can complete their purchase.
</p>

<p style="margin-bottom: 24px;">
  <a href="<%= @app_url %>" class="button" style="display: inline-block; background-color: #008060; color: #ffffff !important; text-decoration: none; padding: 12px 24px; border-radius: 4px; font-weight: 500;">
    View Page Details
  </a>
</p>

<p style="margin-bottom: 16px; color: #6d7175; font-size: 14px;">
  <em>We only alert you when we're confident there's a real issue. This helps us avoid false alarms.</em>
</p>
